    {
      "id": "thornhold",
      "title": "Thornhold",
      "type": "settlement",
      "world": "astrath-deeprealm",
      "visibility": "player",
      "canon": "canon",
      "aliases": [
        "Thorn Hold",
        "The Red City"
      ],
      "tags": [
