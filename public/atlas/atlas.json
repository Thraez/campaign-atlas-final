    {
      "id": "founding-of-thornhold",
      "title": "Founding of Thornhold",
      "type": "event",
      "world": "astrath-deeprealm",
      "visibility": "player",
      "canon": "canon",
      "aliases": [],
      "tags": [
        "founding",
        "thornhold"
      ],
      "summary": "Lord Garron raises the red walls of Thornhold above the iron veins of the Spinegrey range.",
      "images": [],
      "body": "\nForty-seven years after the [[The Sundering|Sundering]], settlers from the eastern\nports broke the first stones of [[Thornhold]] from the cliffside. The\nfoundation feast lasted nine days, ending with the lighting of the Forge of\nGarron — still tended today.\n",
      "bodyHtml": "<p>Forty-seven years after the <a class=\"atlas-wikilink\" data-entity-id=\"the-sundering\" href=\"#/entity/the-sundering\">Sundering</a>, settlers from the eastern\nports broke the first stones of <a class=\"atlas-wikilink\" data-entity-id=\"thornhold\" href=\"#/entity/thornhold\">Thornhold</a> from the cliffside. The\nfoundation feast lasted nine days, ending with the lighting of the Forge of\nGarron — still tended today.</p>\n",
